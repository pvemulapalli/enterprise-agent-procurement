# Crossmint Embedded Wallet — Environment Variables
# Copy to .env.local and fill in your keys from https://www.crossmint.com/console
#
# OTP email branding ("Sign in to …"): Crossmint Console → Settings → Branding
# Set Display name to match lib/crossmint/config.ts → crossmintAppDisplayName

# ── Required (client) ──────────────────────────────────────────────────────────
# Client-side API key (must start with ck_staging_ or ck_production_)
# Required scopes: users.create, users.read, wallets.read, wallets.create,
#   wallets:transactions.create, wallets:transactions.sign, wallets:balance.read
NEXT_PUBLIC_CROSSMINT_API_KEY=

# EVM chain for embedded wallet (default: base-sepolia for staging)
# Staging: base-sepolia, polygon-amoy, ethereum-sepolia, etc.
# Production: base, polygon, ethereum, etc.
NEXT_PUBLIC_CROSSMINT_CHAIN=base-sepolia

# ── Company treasury (client — safe to expose) ───────────────────────────────
# Demo mode simulates treasury balance/funding/payment locally (see lib/crossmint/treasury-demo.ts).
# Live mode requires Crossmint Treasury Wallets enabled on your project (owner: COMPANY).
NEXT_PUBLIC_CROSSMINT_TREASURY_WALLET_ADDRESS=
NEXT_PUBLIC_CROSSMINT_TREASURY_WALLET_ALIAS=lilys-boutique-treasury
NEXT_PUBLIC_CROSSMINT_TREASURY_DISPLAY_NAME=Lily's Boutique Treasury

# SHI vendor payee — external Phantom wallet on Base Sepolia (recipient only, not a signer)
NEXT_PUBLIC_SHI_VENDOR_TREASURY_ADDRESS=0x7996eE8bA9AC0B67dCFd7873970445b4d88c0744

# ── Required (server — company treasury) ─────────────────────────────────────
# Server API key for the company treasury (owner: COMPANY).
# Required scopes: wallets.read, wallets.create, wallets:transactions.create,
#   wallets:transactions.sign, wallets:balance.read, wallets.fund, wallets:signatures.create
CROSSMINT_SERVER_API_KEY=

# Server signer secret — generate yourself (not from Console):
#   CROSSMINT_SIGNER_SECRET="xmsk1_$(openssl rand -hex 32)"
# Used as recovery + operational signer when running npm run create-treasury.
# See https://docs.crossmint.com/wallets/guides/treasury-wallets
CROSSMINT_SIGNER_SECRET=
